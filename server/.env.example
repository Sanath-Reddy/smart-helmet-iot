# Port to run the server on
PORT=3000

# Twilio Credentials (Required for automated SMS notifications. Leave empty for Console Simulation)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Google Places API Key (Required for premium hospital/police finder. Leave empty to use OpenStreetMap fallback)
GOOGLE_PLACES_API_KEY=
